{
  "name": "@sergen/flowkit",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/SergenN/FlowKit"
  },
  "version": "0.0.3",
  "type": "module",
  "main": "./dist/flow-kit.js",
  "module": "./dist/flow-kit.js",
  "types": "./dist/core/main.d.ts",
  "sideEffects": [
    "./dist/flow-kit.js",
    "./dist/flow-kit.umd.cjs",
    "./dist/minimap.js",
    "./dist/background.js",
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/core/main.d.ts",
      "import": "./dist/flow-kit.js",
      "require": "./dist/flow-kit.umd.cjs"
    },
    "./minimap": {
      "types": "./dist/minimap/index.d.ts",
      "import": "./dist/minimap.js"
    },
    "./background": {
      "types": "./dist/background/index.d.ts",
      "import": "./dist/background.js"
    },
    "./style.css": "./dist/flow-kit.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:types",
    "build:types": "tsc -p tsconfig.build.json",
    "build:pages": "vite build --config vite.pages.config.ts",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/d3-drag": "^3.0.7",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-transition": "^3.0.9",
    "@types/d3-zoom": "^3.0.8",
    "prettier": "^3.3.1",
    "typescript": "^5.2.2",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "d3-drag": "^3.0.0",
    "d3-interpolate": "^3.0.1",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0"
  }
}
